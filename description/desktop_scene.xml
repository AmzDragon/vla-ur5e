<!-- Desktop UR5e scene without the mobile base or linear rail. -->
<mujoco model="ur5e desktop scene">
  <include file="ur5e/ur5e_globals.xml" />
  <include file="robotiq_2f85/robotiq2f85_globals.xml" />

  <compiler angle="radian" autolimits="true" />

  <option
    integrator="implicitfast"
    timestep="0.001"
    cone="elliptic"
    impratio="10"
    noslip_iterations="10"
  >
    <flag multiccd="enable" />
  </option>

  <asset>
    <texture
      type="2d"
      name="groundplane"
      builtin="checker"
      mark="edge"
      rgb1="0.2 0.3 0.4"
      rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8"
      width="300"
      height="300"
    />
    <material
      name="groundplane"
      texture="groundplane"
      texuniform="true"
      texrepeat="5 5"
      reflectance="0.2"
    />
    <material
      name="table_gray"
      rgba="0.45 0.45 0.45 1"
      specular="0.25"
      shininess="0.35"
    />
    <material
      name="table_dark_green"
      rgba="0.02 0.20 0.12 1"
      specular="0.35"
      shininess="0.45"
    />
    <mesh name="crate_mesh" file="object/meshes/plastic_crate.obj" scale="0.5 0.5 0.5" />
    <material name="crate_green" rgba="0.02 0.22 0.04 1" specular="0.35" shininess="0.25" />
    <material name="crate_collision" rgba="0 0 0 0" specular="0" shininess="0" />
  </asset>
  <visual>
      <headlight
          ambient="0.3 0.3 0.3"
          diffuse="0.4 0.4 0.4"
          specular="0.1 0.1 0.1" />
    </visual>
  <worldbody>
    
    <light pos="0 -1.5 2.2" dir="0 0 -1" directional="true" castshadow="false"/>
    <light name="spotlight" mode="targetbodycom" target="wrist_2_link" pos="0 1.2 2.0" />
    <camera
        name="right_side_camera"
        pos="0.6 -0.5 1.3"
        fovy="58"
        xyaxes="0.640184 0.768221 -0.000000 -0.549694 0.458079 0.698570"
        mode="fixed"
      />

    <geom
      name="floor"
      pos="0 0 0"
      size="0 0 0.05"
      type="plane"
      material="groundplane"
    />

    <site
      name="scene_camera_optical_frame"
      pos="1.2 -1.8 1.6"
      euler="3.99 0 0.55"
    />


    <!-- 1.2 m x 1.0 m x 0.70 m table centered at the world origin. -->
    <body name="desktop_table" pos="0 0 0">
      <geom
        name="table_top"
        type="box"
        pos="0 0 0.6795"
        size="0.6 0.5 0.0195"
        material="table_gray"
        rgba="0.45 0.45 0.45 1"
        group="2"
      />
      <geom
        name="table_surface"
        type="box"
        pos="0 0 0.6995"
        size="0.6 0.5 0.0005"
        material="table_dark_green"
        rgba="0.02 0.20 0.12 1"
        friction="4.0 0.05 0.005"
        condim="6"
        priority="1"
        solref="0.005 1"
        solimp="0.95 0.99 0.001"
        group="2"
      />
      <geom
        name="front_left_leg"
        type="box"
        pos="-0.52 -0.42 0.33"
        size="0.035 0.035 0.33"
        material="table_gray"
        rgba="0.45 0.45 0.45 1"
        group="2"
      />
      <geom
        name="front_right_leg"
        type="box"
        pos="0.52 -0.42 0.33"
        size="0.035 0.035 0.33"
        material="table_gray"
        rgba="0.45 0.45 0.45 1"
        group="2"
      />
      <geom
        name="rear_left_leg"
        type="box"
        pos="-0.52 0.42 0.33"
        size="0.035 0.035 0.33"
        material="table_gray"
        rgba="0.45 0.45 0.45 1"
        group="2"
      />
      <geom
        name="rear_right_leg"
        type="box"
        pos="0.52 0.42 0.33"
        size="0.035 0.035 0.33"
        material="table_gray"
        rgba="0.45 0.45 0.45 1"
        group="2"
      />

    </body>

    <include file="object/red_cube.xml" />
    <include file="object/yellow_cylinder.xml" />
    <include file="object/cyan_cuboid.xml" />
    <include file="object/white_square_sheet.xml" />
    <include file="object/black_rectangular_sheet.xml" />

    <!-- Keep this body name for the UR5e global contact exclude, but give it no geometry. -->
    <body name="base_platform" pos="0 -0.43 0.5" euler="0 0 1.57">
      <include file="ur5e/ur5e.xml" />
    </body>


  </worldbody>
</mujoco>
